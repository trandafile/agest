# TEMPLATE — copia questo file in `.streamlit/secrets.toml` (locale) oppure
# incolla il contenuto nel pannello Secrets di Streamlit Cloud (produzione).
# `secrets.toml` e' in .gitignore e NON deve mai essere committato.

# --- Google OAuth (bottone di login stile MAIC tasks) ---
# In locale:      GOOGLE_REDIRECT_URI = "http://localhost:8501"
# In produzione:  GOOGLE_REDIRECT_URI = "https://antgest.streamlit.app"
# L'URI deve comparire tra i "Redirect URI autorizzati" del client OAuth
# in Google Cloud Console.
GOOGLE_CLIENT_ID = "<client-id>.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "<client-secret>"
GOOGLE_REDIRECT_URI = "http://localhost:8501"

# --- Database PostgreSQL (Neon) ---
# Connection string POOLED (host con "-pooler"), segreta: mai in UI, mai in git.
[database]
dsn = "postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"

# --- Parametri applicativi ---
[app]
allowed_email_domain = "antecnica.it"   # login consentito solo a *@antecnica.it

# --- (Opzionale) Google Drive: archivio degli estratti conto PDF ---
# Configura UNA delle due modalità.
#
# ① OAuth2 refresh token (CONSIGLIATA, nessuna chiave service account).
#    Ottienilo una volta sola con l'OAuth Playground o scripts/gdrive_oauth.py.
#    client_id/client_secret sono riusati dal login (GOOGLE_CLIENT_ID/SECRET):
#    bastano refresh_token + folder_estratti.
# [gdrive]
# refresh_token   = "1//..."
# folder_estratti = "<ID della cartella Drive>"
#    (client_id / client_secret opzionali qui, solo se usi un client diverso)
#
# ② Service account (se l'organizzazione consente le chiavi JSON):
# [gdrive]
# service_account = '''{ ...incolla qui il JSON del service account... }'''
# folder_estratti = "<ID della cartella Drive>"
