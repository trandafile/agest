# TEMPLATE — copia in `.env` e inserisci i valori reali (`.env` e' in .gitignore).
# Usato SOLO in sviluppo locale. In produzione (Streamlit Cloud) si usano i Secrets.

# Endpoint POOLED (host con "-pooler"): usato dall'app a runtime.
DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# Endpoint DIRETTO: usato per applicare migrazioni/DDL (consigliato da Neon).
DATABASE_URL_DIRECT=postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<db>?sslmode=require
